{
  "name": "connect-transfer-react-native-sdk",
  "version": "1.1.0",
  "description": "Connect Transfer React Native SDK for Mastercard Open Finance Connect",
  "main": "lib/commonjs/index",
  "module": "lib/module/index",
  "types": "lib/typescript/src/index.d.ts",
  "license": "MIT",
  "author": "connect-transfer-react-native-sdk",
  "react-native": "src/index",
  "source": "src/index",
  "files": [
    "lib",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "src",
    "!**/.*"
  ],
  "scripts": {
    "example": "yarn workspace connect-transfer-react-native-sdk-example",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "clean": "del-cli android/build example/android/build example/android/app/build example/ios/build lib",
    "prebuild": "node scripts/generate-version.js",
    "build": "bob build && npm pack",
    "prettier-check": "prettier --config .prettierrc.js --check ./src/",
    "prettier-fix": "prettier --config .prettierrc.js --write ./src/",
    "release": "release-it",
    "test:version_bump": "test $npm_package_version != $(npm show $npm_package_name version) || (echo 'Failing... You must bump package.json and package-lock.json' && exit 1)",
    "prepare": "bob build"
  },
  "keywords": [
    "Mastercard",
    "Mastercard Open Finance Connect"
  ],
  "dependencies": {
    "@gorhom/bottom-sheet": "5.2.8",
    "@reduxjs/toolkit": "2.11.2",
    "axios": "1.14.0",
    "i18next": "26.0.3",
    "react-i18next": "17.0.2",
    "react-native-url-polyfill": "3.0.0",
    "react-redux": "9.2.0"
  },
  "devDependencies": {
    "@atomicfi/transact-react-native": "3.15.1",
    "@babel/core": "7.29.0",
    "@babel/preset-env": "7.29.2",
    "@babel/runtime": "7.29.2",
    "@commitlint/config-conventional": "20.5.0",
    "@react-native-community/cli": "20.1.3",
    "@react-native/babel-preset": "0.84.1",
    "@react-native/eslint-config": "0.84.1",
    "@react-native/metro-config": "0.84.1",
    "@react-native/typescript-config": "0.84.1",
    "@release-it/conventional-changelog": "10.0.6",
    "@testing-library/jest-native": "5.4.3",
    "@testing-library/react-native": "13.3.3",
    "@types/jest": "30.0.0",
    "@types/react": "19.2.14",
    "@types/react-test-renderer": "19.1.0",
    "commitlint": "20.5.0",
    "del-cli": "7.0.0",
    "eslint": "10.1.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "jest": "30.3.0",
    "pod-install": "1.0.14",
    "prettier": "3.8.1",
    "react": "19.2.3",
    "react-native": "0.84.1",
    "react-native-builder-bob": "0.41.0",
    "react-native-gesture-handler": "2.30.1",
    "react-native-inappbrowser-reborn": "3.7.1",
    "react-native-reanimated": "4.3.0",
    "react-native-worklets": "0.8.1",
    "react-test-renderer": "19.2.3",
    "release-it": "19.2.4",
    "turbo": "2.9.3",
    "typescript": "6.0.2",
    "yarn-audit-fix": "10.1.1"
  },
  "peerDependencies": {
    "@atomicfi/transact-react-native": "3.15.1",
    "react": ">=19.0.0",
    "react-native": ">=0.84.0",
    "react-native-gesture-handler": "2.30.1",
    "react-native-inappbrowser-reborn": "3.7.1",
    "react-native-reanimated": "4.3.0"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release ${version}",
      "tagName": "v${version}"
    },
    "npm": {
      "publish": true
    },
    "github": {
      "release": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": "angular"
      }
    }
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "@react-native"
    ]
  },
  "eslintIgnore": [
    "node_modules/",
    "lib/"
  ],
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
