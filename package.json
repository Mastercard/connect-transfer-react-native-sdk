{
  "name": "connect-transfer-react-native-sdk",
  "version": "0.0.1",
  "private": true,
  "description": "React Native SDK for Mastercard Open Banking Connect",
  "license": "MIT",
  "author": "connect-transfer-react-native-sdk",
  "react-native": "src/index",
  "source": "./index.tsx",
  "files": [
    "./",
    "lib",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "src",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/.*"
  ],
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "example": "yarn workspace connect-transfer-react-native-sdk-example",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "clean": "del-cli android/build example/android/build example/android/app/build example/ios/build lib",
    "build": "bob build",
    "prettier-check": "prettier --config .prettierrc.js --check ./src/",
    "prettier-fix": "prettier --config .prettierrc.js --write ./src/",
    "release": "release-it",
    "test:version_bump": "test $npm_package_version != $(npm show $npm_package_name version) || (echo 'Failing... You must bump package.json and package-lock.json' && exit 1)",
    "prepare": "bob build"
  },
  "keywords": [
    "Mastercard",
    "Mastercard Open Banking Connect"
  ],
  "dependencies": {
    "@atomicfi/transact-react-native": "3.8.2",
    "@gorhom/bottom-sheet": "^5.1.1",
    "@react-navigation/native": "7.0.14",
    "@react-navigation/native-stack": "7.2.0",
    "@reduxjs/toolkit": "2.5.1",
    "axios": "1.7.9",
    "bob": "^3.1.0",
    "i18next": "24.2.2",
    "react-i18next": "*",
    "react-native-gesture-handler": "2.23.1",
    "react-native-inappbrowser-reborn": ">=3.6",
    "react-native-reanimated": "3.16.7",
    "react-native-safe-area-context": "5.2.0",
    "react-native-screens": "4.7.0",
    "react-native-url-polyfill": "2.0.0",
    "react-redux": "9.2.0"
  },
  "engines": {
    "node": ">=18"
  },
  "main": "./lib/commonjs/index.js",
  "module": "./lib/module/index.js",
  "types": "./lib/typescript/commonjs/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./lib/typescript/module/index.d.ts",
        "default": "./lib/module/index.js"
      },
      "require": {
        "types": "./lib/typescript/commonjs/index.d.ts",
        "default": "./lib/commonjs/index.js"
      }
    }
  },
  "devDependencies": {
    "@babel/core": "7.26.9",
    "@babel/preset-env": "7.26.9",
    "@babel/runtime": "^7.26.9",
    "@commitlint/config-conventional": "^19.7.1",
    "@react-native/babel-preset": "0.77.1",
    "@react-native/eslint-config": "^0.77.1",
    "@react-native/metro-config": "0.77.1",
    "@react-native/typescript-config": "0.77.1",
    "@release-it/conventional-changelog": "^10.0.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.1.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.0.10",
    "@types/react-native": "0.73.0",
    "@types/react-test-renderer": "^19.0.0",
    "babel-jest": "^29.7.0",
    "commitlint": "^19.7.1",
    "del-cli": "^6.0.0",
    "eslint": "^9.20.1",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.3",
    "jest": "^29.7.0",
    "metro-react-native-babel-preset": "^0.77.0",
    "pod-install": "^0.3.4",
    "prettier": "^3.5.1",
    "react": "19.0.0",
    "react-native": "^0.77.1",
    "react-native-builder-bob": "^0.37.0",
    "react-test-renderer": "19.0.0",
    "release-it": "^18.1.2",
    "semver": ">=7.7.1",
    "turbo": "^2.4.2",
    "typescript": "^5.7.3",
    "yarn-audit-fix": "^10.1.1"
  },
  "resolutions": {
    "@types/react": "17.0.21",
    "semver": ">=7.5.4"
  },
  "peerDependencies": {
    "react": ">=16.13",
    "react-native": ">=0.63",
    "react-native-inappbrowser-reborn": ">=3.6"
  },
  "packageManager": "yarn@1.22.22",
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release ${version}",
      "tagName": "v${version}"
    },
    "npm": {
      "publish": true
    },
    "github": {
      "release": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": "angular"
      }
    }
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "@react-native"
    ]
  },
  "eslintIgnore": [
    "node_modules/",
    "lib/"
  ],
  "react-native-builder-bob": {
    "source": "./",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
