{
  "name": "connect-transfer-react-native-sdk",
  "version": "1.1.0",
  "description": "Connect Transfer React Native SDK for Mastercard Open Finance Connect",
  "main": "lib/commonjs/index",
  "module": "lib/module/index",
  "types": "lib/typescript/src/index.d.ts",
  "license": "MIT",
  "author": "connect-transfer-react-native-sdk",
  "react-native": "src/index",
  "source": "src/index",
  "files": [
    "lib",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "src",
    "!**/.*"
  ],
  "scripts": {
    "example": "yarn workspace connect-transfer-react-native-sdk-example",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "clean": "del-cli android/build example/android/build example/android/app/build example/ios/build lib",
    "prebuild": "node scripts/generate-version.js",
    "build": "bob build && npm pack",
    "prettier-check": "prettier --config .prettierrc.js --check ./src/",
    "prettier-fix": "prettier --config .prettierrc.js --write ./src/",
    "release": "release-it",
    "test:version_bump": "test $npm_package_version != $(npm show $npm_package_name version) || (echo 'Failing... You must bump package.json and package-lock.json' && exit 1)",
    "prepare": "bob build"
  },
  "keywords": [
    "Mastercard",
    "Mastercard Open Finance Connect"
  ],
  "dependencies": {
    "@gorhom/bottom-sheet": "5.2.8",
    "@reduxjs/toolkit": "2.11.2",
    "axios": "1.13.6",
    "i18next": "24.2.3",
    "react-i18next": "15.7.4",
    "react-native-url-polyfill": "2.0.0",
    "react-redux": "9.2.0"
  },
  "devDependencies": {
    "@atomicfi/transact-react-native": "3.11.1",
    "@babel/core": "7.29.0",
    "@babel/preset-env": "7.29.0",
    "@babel/runtime": "^7.28.6",
    "@commitlint/config-conventional": "^19.8.1",
    "@react-native-community/cli": "^18.0.1",
    "@react-native/babel-preset": "0.77.1",
    "@react-native/eslint-config": "0.77.1",
    "@react-native/metro-config": "0.77.1",
    "@react-native/typescript-config": "0.77.1",
    "@release-it/conventional-changelog": "^10.0.5",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "19.2.14",
    "@types/react-native": "0.73.0",
    "@types/react-test-renderer": "19.1.0",
    "babel-jest": "^29.7.0",
    "commitlint": "^19.8.1",
    "del-cli": "^6.0.0",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^29.7.0",
    "metro-react-native-babel-preset": "^0.77.0",
    "pod-install": "^0.3.10",
    "prettier": "^3.8.1",
    "react": "19.2.4",
    "react-native": "0.77.1",
    "react-native-builder-bob": "0.37.0",
    "react-native-gesture-handler": "2.25.0",
    "react-native-inappbrowser-reborn": "3.7.0",
    "react-native-reanimated": "3.17.4",
    "react-test-renderer": "19.2.4",
    "release-it": "^18.1.2",
    "semver": ">=7.7.4",
    "turbo": "^2.8.13",
    "typescript": "^5.9.3",
    "yarn-audit-fix": "^10.1.1"
  },
  "peerDependencies": {
    "@atomicfi/transact-react-native": "3.11.1",
    "react": ">=18.0.0",
    "react-native": ">=0.71.0",
    "react-native-gesture-handler": "2.25.0",
    "react-native-inappbrowser-reborn": "3.7.0",
    "react-native-reanimated": "3.17.4"
  },
  "resolutions": {
    "@types/react": "19.0.10",
    "semver": "7.7.1"
  },
  "packageManager": "yarn@1.22.22",
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release ${version}",
      "tagName": "v${version}"
    },
    "npm": {
      "publish": true
    },
    "github": {
      "release": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": "angular"
      }
    }
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "@react-native"
    ]
  },
  "eslintIgnore": [
    "node_modules/",
    "lib/"
  ],
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "engines": {
    "node": ">=18"
  }
}
